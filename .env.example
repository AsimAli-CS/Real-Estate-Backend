# Server
PORT=3000

# environment: local | dev | prod | staging
environment=local

# MongoDB connection string (used when environment=local)
mongodbUri=mongodb://localhost:27017/real-estate

# JWT secret used to sign/verify access tokens
jwtKey=your_jwt_secret_here

# JWT secret used to sign/verify email verification tokens
verifyKey=your_verify_secret_here

# Secret key used for encrypting/decrypting data (krypta)
kryptaSecretKey=your_krypta_secret_here
